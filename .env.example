VITE_GISCUS_REPO=
VITE_GISCUS_REPO_ID=
VITE_GISCUS_CATEGORY=General
VITE_GISCUS_CATEGORY_ID=
VITE_GISCUS_MAPPING=pathname
VITE_GISCUS_STRICT=0
VITE_GISCUS_REACTIONS_ENABLED=1
VITE_GISCUS_INPUT_POSITION=bottom
VITE_GISCUS_THEME=nexus
VITE_GISCUS_LANG=zh-CN

VITE_CAPTURE_GISCUS_REPO=
VITE_CAPTURE_GISCUS_REPO_ID=
VITE_CAPTURE_GISCUS_CATEGORY=General
VITE_CAPTURE_GISCUS_CATEGORY_ID=
VITE_CAPTURE_GISCUS_MAPPING=specific
VITE_CAPTURE_GISCUS_STRICT=0
VITE_CAPTURE_GISCUS_REACTIONS_ENABLED=1
VITE_CAPTURE_GISCUS_INPUT_POSITION=bottom
VITE_CAPTURE_GISCUS_THEME=nexus
VITE_CAPTURE_GISCUS_LANG=zh-CN

# Code runner mode:
# - frontend: run Go code in the browser through the bundled WASM runner.
# - backend: call a Sandkasten HTTP API, for example http://127.0.0.1:8080 locally.
# Vite exposes these values in the built JavaScript, so API tokens here must be public client tokens.
VITE_CODE_RUNNER_MODE=frontend
VITE_CODE_RUNNER_API_URL=
VITE_CODE_RUNNER_API_TOKEN=
